---
import { services } from "../data/services";
---

<section id="servicios" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4">
    <div class="max-w-3xl">
      <p class="font-black uppercase tracking-[0.25em] text-yellow-600">Servicios</p>
      <h2 class="mt-4 text-4xl font-black tracking-tight text-slate-950 md:text-5xl">
        Servicios profesionales de desatascos y fontanería
      </h2>
      <p class="mt-5 text-lg leading-8 text-slate-600">
        En Desatascos JF trabajamos con servicios claros y orientados a resolver problemas reales en viviendas,
        comunidades, locales y empresas.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {services.map((service, index) => (
        <article class="rounded-3xl border border-slate-200 bg-slate-50 p-7 transition hover:-translate-y-1 hover:shadow-xl">
          <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-950 text-xl font-black text-yellow-300">
            {index + 1}
          </div>
          <h3 class="text-xl font-black text-slate-950">{service.title}</h3>
          <p class="mt-4 leading-7 text-slate-600">{service.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
