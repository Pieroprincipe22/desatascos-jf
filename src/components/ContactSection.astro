---
import { siteConfig } from "../data/site";

const phoneHref = siteConfig.phone ? `tel:${siteConfig.phone.replaceAll(" ", "")}` : "#contacto";
const whatsappHref = siteConfig.whatsapp
  ? `https://wa.me/${siteConfig.whatsapp.replaceAll(" ", "").replace("+", "")}`
  : "#contacto";
---

<section id="contacto" class="bg-yellow-400 py-24">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 lg:grid-cols-[1fr_0.8fr] lg:items-center">
    <div>
      <p class="font-black uppercase tracking-[0.25em] text-slate-800">Contacto</p>
      <h2 class="mt-4 text-4xl font-black tracking-tight text-slate-950 md:text-5xl">
        ¿Tienes un atasco o una avería de fontanería?
      </h2>
      <p class="mt-6 text-lg leading-8 text-slate-800">
        Contacta con Desatascos JF para recibir atención profesional en Ciudad Real y alrededores.
        Trabajamos para viviendas, comunidades, negocios y empresas.
      </p>
    </div>

    <div class="rounded-3xl bg-slate-950 p-8 text-white shadow-2xl">
      <h3 class="text-2xl font-black">Desatascos JF</h3>
      <p class="mt-3 text-slate-300">{siteConfig.description}</p>

      <div class="mt-8 grid gap-4">
        <a href={phoneHref} class="rounded-full bg-yellow-400 px-6 py-4 text-center font-black text-slate-950 transition hover:bg-yellow-300">
          Contactar ahora
        </a>
        <a href={whatsappHref} class="rounded-full border border-white/20 px-6 py-4 text-center font-black text-white transition hover:border-yellow-300 hover:text-yellow-300">
          Enviar WhatsApp
        </a>
      </div>

      <p class="mt-6 text-sm leading-6 text-slate-400">
        Servicio profesional de desatascos, camión cuba, limpieza de tuberías y fontanería.
      </p>
    </div>
  </div>
</section>
