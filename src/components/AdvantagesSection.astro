---
import { advantages } from "../data/advantages";
---

<section id="ventajas" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-black uppercase tracking-[0.25em] text-yellow-600">
        Por qué elegir Desatascos JF
      </p>

      <h2 class="mt-4 text-4xl font-black tracking-tight text-slate-950 md:text-5xl">
        Atención cercana, rápida y profesional
      </h2>

      <p class="mt-5 text-lg leading-8 text-slate-600">
        Una empresa de Ciudad Real orientada a resolver problemas de desatascos, tuberías
        y fontanería con un trato claro desde el primer contacto.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-5">
      {
        advantages.map((advantage, index) => (
          <article class="rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition hover:-translate-y-1 hover:border-yellow-300 hover:bg-white hover:shadow-lg">
            <span class="mb-7 inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-950 text-sm font-black text-yellow-300">
              {String(index + 1).padStart(2, "0")}
            </span>

            <h3 class="text-xl font-black leading-tight text-slate-950">
              {advantage.title}
            </h3>

            <p class="mt-3 text-sm leading-6 text-slate-600">
              {advantage.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
