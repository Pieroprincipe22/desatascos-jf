---
import { reasons } from "../data/reasons";
---

<section class="bg-slate-950 py-24 text-white">
  <div class="mx-auto max-w-7xl px-4">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="font-black uppercase tracking-[0.25em] text-yellow-300">Por qué elegirnos</p>
        <h2 class="mt-4 text-4xl font-black tracking-tight md:text-5xl">
          Un servicio cercano, claro y profesional
        </h2>
        <p class="mt-6 text-lg leading-8 text-slate-300">
          En Desatascos JF ayudamos a resolver problemas de desatascos, tuberías y fontanería
          con un trato directo y orientado a dar una solución eficaz.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {reasons.map((reason) => (
          <article class="rounded-3xl border border-white/10 bg-white/10 p-6">
            <h3 class="text-xl font-black text-yellow-300">{reason.title}</h3>
            <p class="mt-3 leading-7 text-slate-300">{reason.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
