---
import { problems } from "../data/problems";
---

<section id="problemas" class="bg-slate-100 py-24">
  <div class="mx-auto max-w-7xl px-4">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="font-black uppercase tracking-[0.25em] text-yellow-600">Problemas frecuentes</p>
        <h2 class="mt-4 text-4xl font-black tracking-tight text-slate-950 md:text-5xl">
          Problemas que resolvemos habitualmente
        </h2>
        <p class="mt-5 text-lg leading-8 text-slate-600">
          Si tienes un atasco, mal olor, fuga o una avería relacionada con tuberías o fontanería,
          Desatascos JF puede ayudarte en Ciudad Real y alrededores.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {problems.map((problem) => (
          <div class="rounded-2xl bg-white p-5 font-bold text-slate-800 shadow-sm">
            <span class="mr-2 text-yellow-500">●</span>
            {problem}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
