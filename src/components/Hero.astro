---
import { siteConfig } from "../data/site";
---

<section class="relative overflow-hidden bg-slate-950 pt-32 text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(250,204,21,0.22),_transparent_35%),linear-gradient(135deg,_#020617_0%,_#0f172a_45%,_#111827_100%)]"></div>

  <div class="relative mx-auto grid max-w-7xl gap-12 px-4 py-20 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
      <p class="mb-5 inline-flex rounded-full border border-yellow-400/40 bg-yellow-400/10 px-4 py-2 text-sm font-bold text-yellow-300">
        Servicio en Ciudad Real y alrededores
      </p>

      <h1 class="max-w-4xl text-5xl font-black leading-tight tracking-tight md:text-7xl">
        Desatascos JF en Ciudad Real
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300 md:text-xl">
        Servicio profesional de desatascos urgentes, camión cuba, limpieza de tuberías y fontanería.
        Atendemos a particulares, comunidades, negocios y empresas con rapidez, claridad y trato profesional.
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a
          href="#contacto"
          class="rounded-full bg-yellow-400 px-8 py-4 text-center text-base font-black text-slate-950 transition hover:bg-yellow-300"
        >
          Llamar ahora
        </a>
        <a
          href="#servicios"
          class="rounded-full border border-white/20 px-8 py-4 text-center text-base font-black text-white transition hover:border-yellow-300 hover:text-yellow-300"
        >
          Ver servicios
        </a>
      </div>
    </div>

    <div class="rounded-[2rem] border border-white/10 bg-white/10 p-6 shadow-2xl backdrop-blur">
      <div class="rounded-[1.5rem] bg-slate-900 p-8">
        <p class="text-sm font-bold uppercase tracking-[0.25em] text-yellow-300">
          Atención rápida
        </p>
        <h2 class="mt-4 text-3xl font-black">
          Desatascos, limpieza y fontanería cuando más lo necesitas.
        </h2>
        <div class="mt-8 grid gap-4">
          <div class="rounded-2xl bg-white/10 p-5">
            <p class="font-bold">Desatascos urgentes</p>
            <p class="mt-1 text-sm text-slate-300">WC, fregaderos, duchas, bajantes y tuberías.</p>
          </div>
          <div class="rounded-2xl bg-white/10 p-5">
            <p class="font-bold">Camión cuba</p>
            <p class="mt-1 text-sm text-slate-300">Para trabajos de limpieza y desatascos complejos.</p>
          </div>
          <div class="rounded-2xl bg-white/10 p-5">
            <p class="font-bold">Fontanería</p>
            <p class="mt-1 text-sm text-slate-300">Reparaciones, fugas y averías de agua.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
